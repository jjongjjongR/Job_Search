# 2026-03-30 신규: FastAPI 내부 AI 서버 실행에 필요한 기본 환경변수 예시를 정리한다.
# AI Server
AI_APP_NAME=world-job-search-ai
AI_ENV=development
AI_PORT=8000
AI_LOG_LEVEL=INFO

# Internal security
INTERNAL_API_SHARED_SECRET=change-me
ALLOW_TRUSTED_INTERNAL_NETWORK=true

# Redis for LangGraph session state and TTL cleanup
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_SECONDS=600

# PostgreSQL metadata access (optional for future minimal session metadata reads)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=world_job_search

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./storage
S3_BUCKET=
S3_REGION=ap-northeast-2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PRESIGNED_EXPIRES_SECONDS=600

# LLM / orchestration
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REASONING_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# STT / TTS / Vision tool providers
STT_PROVIDER=openai
TTS_PROVIDER=openai
VISION_PROVIDER=openai
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_VISION_MODEL=gpt-4.1-mini

# File and session limits
MAX_RESUME_FILE_MB=10
MAX_PORTFOLIO_FILE_MB=20
MAX_VIDEO_FILE_MB=120
MAX_VIDEO_DURATION_SECONDS=120
MAX_TOTAL_QUESTIONS=10
MAX_FOLLOWUP_PER_TOPIC=2

# Cleanup policy
TEMP_FILE_RETENTION_SECONDS=600
DELETE_FINISHED_SESSION_AFTER_SECONDS=600

# CORS is not intended for public exposure, but kept for local internal dev
INTERNAL_ALLOWED_ORIGINS=http://localhost:3001
